-- Fonction pour ouvrir les œufs (hatching)
local function doHatching()
    if not config.autoHatch or not HatchRemote then return end

    local function hatchLoop()
        spawn(function()
            pcall(function()
                HatchRemote:FireServer()
            end)
        end)
        task.wait(config.eggDelay)
        if config.autoHatch then
            hatchLoop()  -- Rappel récursif
        end
    end

    hatchLoop()  -- Démarre la boucle
end

-- Fonction pour planter les œufs
local function doPlanting()
    if not config.autoPlant or #config.eggsSelected == 0 or not PlantRemote then return end

    for _, zone in ipairs(config.eggsSelected) do
        spawn(function()
            pcall(function()
                PlantRemote:FireServer(zone)
            end)
        end)
        task.wait(config.eggDelay)
    end
end

-- Fonction pour nourrir les nids
local function doNests()
    if not config.autoNests or not FeedRemote then return end

    local nests = updateNests()
    if not nests then return end

    for _, nest in ipairs(nests:GetChildren()) do
        spawn(function()
            pcall(function()
                FeedRemote:FireServer(nest)
            end)
        end)
        task.wait(config.eggDelay)
    end
end

