-- Cache de pets e ninhos
local petCache = {}
local nestCache = nil
local lastPetUpdate = 0
local lastNestUpdate = 0
local PET_UPDATE_INTERVAL = 1.0
local NEST_UPDATE_INTERVAL = 30
 
local function updatePets()
    local now = os.clock()
    if now - lastPetUpdate > PET_UPDATE_INTERVAL then
        if LocalPlayer.Character then
            local petsObj = LocalPlayer.Character:FindFirstChild("Pets")
            if petsObj then
                local pets = petsObj:GetChildren()
                for i, v in ipairs(pets) do petCache[i] = v end
                for i = #pets + 1, #petCache do petCache[i] = nil end
            else
                for i = 1, #petCache do petCache[i] = nil end
            end
        else
            for i = 1, #petCache do petCache[i] = nil end
        end
        lastPetUpdate = now
    end
    return petCache
end
 
local function updateNests()
    local now = os.clock()
    if now - lastNestUpdate > NEST_UPDATE_INTERVAL then
        nestCache = Workspace:FindFirstChild("Nests")
        lastNestUpdate = now
    end
    return nestCache
end
 
